# Pixiv Agent 配置示例
# 复制本文件为 .env 并填写实际值

# Pixiv Refresh Token（通过 https://gist.github.com/ZipFile/c9ebedb224406f4f11845ab700124362 获取）
PIXIV_REFRESH_TOKEN=your_pixiv_refresh_token_here

# 节点鉴权密钥（主服务器用此 key 调用本节点 API）
AGENT_API_KEY=change_me_to_a_strong_random_secret

# 监听端口
PORT=8100

# 图片和 SQLite 缓存目录（相对于项目根目录）
DATA_DIR=./data

# Pixiv API 速率限制（每秒允许的 API 请求数，默认 0.5 即每2秒1次）
RATE_LIMIT=0.5

# 单次同步一个作者时最多拉取的作品数（0 = 无限制，小心 API 限制）
MAX_ARTWORKS_PER_AUTHOR=0

# 图片下载并发数（建议 1-3，过高容易被 ban）
DOWNLOAD_CONCURRENCY=2

# 节点名称（日志/主服务器展示用）
NODE_NAME=agent-01

# 网络代理设置（支持 http / https / socks5 代理，可选）
# HTTP_PROXY=http://127.0.0.1:7890
